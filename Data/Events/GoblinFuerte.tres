[sub_resource type="Resource" id="Resource_bv76d"]
script = ExtResource("2_bv76d")
texto_boton = "Salir corriendo"
stat_usada = "velocidad"
multiplicador_dificultad = 1.2000000000000002
texto_exito = "Mas vale fuerza que maña....O es al revés? Mmmm...Lo importante es que por suerte parecia que el goblin se saltaba el dia de piernas, bien hecho!"
texto_fracaso = "A DONDE VAS? Esuchas mientras intentas salir corriendo. Miras para atrás y ves al Goblin volando apunto de hacerte un Súplex. Oh oh."
